<div style="max-width: 800px; margin: 50px auto; padding: 20px;">
  <h1>Welcome, <%= @volunteer.full_name %>!</h1>
  
  <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin: 20px 0;">
    <h2>Your Profile</h2>
    
    <p><strong>Username:</strong> <%= @volunteer.username %></p>
    <p><strong>Full Name:</strong> <%= @volunteer.full_name %></p>
    <p><strong>Email:</strong> <%= @volunteer.email %></p>
    <p><strong>Phone Number:</strong> <%= @volunteer.phone_number || "Not provided" %></p>
    <p><strong>Address:</strong> <%= @volunteer.address || "Not provided" %></p>
    <p><strong>Skills/Interests:</strong> <%= @volunteer.skills_interests || "Not provided" %></p>
    <p><strong>Total Hours Volunteered:</strong> <%= @volunteer.total_hours %> hours</p>
  </div>
  
  <div style="margin-top: 20px;">
    <%= link_to "Edit Profile", edit_volunteer_path(@volunteer), style: "padding: 10px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px; margin-right: 10px;" %>
    
    <%= button_to "Delete Account", volunteer_path(@volunteer), method: :delete, 
        data: { confirm: "Are you sure? This action cannot be undone." },
        style: "padding: 10px 20px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; display: inline-block;" %>
    
    <%= button_to "Logout", logout_path, method: :delete,
        style: "padding: 10px 20px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; display: inline-block; margin-left: 10px;" %>
  </div>
  
  <div style="margin-top: 40px;">
    <h3>Quick Links</h3>
    <ul>
      <li><%= link_to "View Available Events", events_path %></li>
      <li><%= link_to "My Events", volunteer_assignments_path %></li>
      <li><%= link_to "Volunteer History", volunteer_assignments_path %></li>
    </ul>
  </div>
</div>