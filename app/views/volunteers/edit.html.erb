<div style="max-width: 600px; margin: 50px auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px;">
  <h1>Edit Your Profile</h1>
  
  <%= form_with(model: @volunteer, local: true) do |f| %>
    <% if @volunteer.errors.any? %>
      <div style="color: red; margin-bottom: 20px; padding: 10px; background-color: #fee; border: 1px solid red; border-radius: 4px;">
        <h3><%= pluralize(@volunteer.errors.count, "error") %> prohibited your profile from being saved:</h3>
        <ul>
          <% @volunteer.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <p style="background-color: #fff3cd; padding: 10px; border-radius: 4px; margin-bottom: 20px;">
      <strong>Note:</strong> Username cannot be changed. Leave password fields blank to keep your current password.
    </p>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :full_name, "Full Name: *" %>
      <%= f.text_field :full_name, required: true, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :email, "Email: *" %>
      <%= f.email_field :email, required: true, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :phone_number, "Phone Number:" %>
      <%= f.text_field :phone_number, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :address, "Address:" %>
      <%= f.text_area :address, rows: 3, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :skills_interests, "Skills / Interests:" %>
      <%= f.text_area :skills_interests, rows: 3, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <hr style="margin: 30px 0;">
    
    <h3>Change Password</h3>
    <p style="font-size: 14px; color: #666;">Leave blank to keep current password</p>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :password, "New Password:" %>
      <%= f.password_field :password, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-bottom: 15px;">
      <%= f.label :password_confirmation, "Confirm New Password:" %>
      <%= f.password_field :password_confirmation, style: "width: 100%; padding: 8px; margin-top: 5px;" %>
    </div>
    
    <div style="margin-top: 20px;">
      <%= f.submit "Update Profile", style: "padding: 10px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; margin-right: 10px;" %>
      <%= link_to "Cancel", volunteer_path(@volunteer), style: "padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px;" %>
    </div>
  <% end %>
</div>