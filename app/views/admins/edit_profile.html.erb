<div style="max-width: 600px; margin: 50px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; background-color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h1 style="margin-top: 0; margin-bottom: 30px; color: #343a40;">Edit Admin Profile</h1>
  
  <%= form_with model: @admin, url: admin_profile_path, method: :patch, local: true do |f| %>
    <% if @admin.errors.any? %>
      <div style="color: #721c24; background-color: #f8d7da; margin-bottom: 25px; padding: 15px; border: 1px solid #f5c6cb; border-radius: 4px;">
        <h3 style="margin-top: 0; margin-bottom: 10px; font-size: 18px;">
          <%= pluralize(@admin.errors.count, "error") %> prohibited this profile from being saved:
        </h3>
        <ul style="margin-bottom: 0; padding-left: 20px;">
          <% @admin.errors.full_messages.each do |msg| %>
            <li style="margin-bottom: 5px;"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Account Section -->
    <div style="background-color: #e7f3ff; padding: 20px; border-radius: 8px; margin-bottom: 25px; border-left: 4px solid #007bff;">
      <h2 style="margin: 0 0 20px 0; color: #004085; font-size: 18px;">🔐 Account Information</h2>
      
      <div style="margin-bottom: 20px;">
        <%= f.label :username, "Username:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.text_field :username, 
            disabled: true,
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box; background-color: #e9ecef; color: #6c757d; font-family: monospace;" %>
        <small style="color: #6c757d; font-size: 14px; display: block; margin-top: 5px;">
          ⓘ Username cannot be changed
        </small>
      </div>
    </div>

    <!-- Profile Section -->
    <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 25px; border-left: 4px solid #28a745;">
      <h2 style="margin: 0 0 20px 0; color: #495057; font-size: 18px;">👤 Profile Details</h2>
      
      <div style="margin-bottom: 20px;">
        <%= f.label :name, "Full Name:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.text_field :name, 
            placeholder: "e.g., John Smith",
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>

      <div style="margin-bottom: 0;">
        <%= f.label :email, "Email Address:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.email_field :email, 
            placeholder: "e.g., admin@example.com",
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>
    </div>

    <!-- Password Notice -->
    <div style="background-color: #fff3cd; padding: 15px; border-radius: 4px; margin-bottom: 25px; border: 1px solid #ffc107;">
      <p style="margin: 0; color: #856404; font-size: 14px;">
        <strong>ℹ️ Note:</strong> Password changes are not available through this form. Contact system administrator to reset your password if needed.
      </p>
    </div>

    <!-- Action Buttons -->
    <div style="margin-top: 30px; display: flex; gap: 10px;">
      <%= f.submit "Save Changes", 
          style: "flex: 1; padding: 12px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold;" %>
      <%= link_to "Cancel", admin_path, 
          style: "flex: 1; padding: 12px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-size: 16px; font-weight: bold; display: block; box-sizing: border-box;" %>
    </div>
  <% end %>
</div>