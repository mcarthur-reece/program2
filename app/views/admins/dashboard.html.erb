<div style="max-width: 1400px; margin: 50px auto; padding: 20px;">

  <%# Header %>
  <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 40px; padding-bottom: 20px; border-bottom: 2px solid #dee2e6;">
    <div>
      <h1 style="margin: 0 0 10px 0; color: #343a40; font-size: 36px;">Admin Dashboard</h1>
      <p style="margin: 0; color: #6c757d; font-size: 16px;">
        Welcome back, <strong style="color: #343a40;"><%= current_admin.name %></strong>. Manage volunteers, events, and approvals from here.
      </p>
    </div>
    <%= button_to "Log Out", logout_path, method: :delete,
        style: "padding: 10px 20px; background-color: #6c757d; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 14px; font-weight: bold;" %>
  </div>

  <%# Stats Cards %>
  <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 40px;">

    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 25px; border-radius: 12px; color: white; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="font-size: 40px; margin-bottom: 10px;">👥</div>
      <div style="font-size: 14px; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px;">Total Volunteers</div>
      <div style="font-size: 36px; font-weight: bold;"><%= @volunteer_count %></div>
    </div>

    <div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 25px; border-radius: 12px; color: white; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="font-size: 40px; margin-bottom: 10px;">📅</div>
      <div style="font-size: 14px; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px;">Total Events</div>
      <div style="font-size: 36px; font-weight: bold;"><%= @event_count %></div>
    </div>

    <div style="background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%); padding: 25px; border-radius: 12px; color: #856404; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="font-size: 40px; margin-bottom: 10px;">⏳</div>
      <div style="font-size: 14px; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px;">Pending Sign-ups</div>
      <div style="font-size: 36px; font-weight: bold;"><%= @pending_assignments %></div>
    </div>

    <div style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%); padding: 25px; border-radius: 12px; color: #155724; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
      <div style="font-size: 40px; margin-bottom: 10px;">✅</div>
      <div style="font-size: 14px; opacity: 0.9; margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px;">Approved</div>
      <div style="font-size: 36px; font-weight: bold;"><%= @approved_assignments %></div>
    </div>

  </div>

  <%# Quick Actions + System Overview side by side %>
  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">

    <%# Quick Actions %>
    <div style="background-color: white; padding: 30px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
      <h2 style="margin: 0 0 25px 0; color: #343a40; font-size: 24px;">Quick Actions</h2>
      <div style="display: flex; flex-direction: column; gap: 12px;">

        <%= link_to edit_admin_profile_path, style: "display: block; padding: 15px 20px; background-color: #e7f3ff; color: #004085; text-decoration: none; border-radius: 8px; font-weight: 500; border: 2px solid transparent;" do %>
          <span style="font-size: 20px; margin-right: 10px;">👤</span>Edit Admin Profile
        <% end %>

        <%= link_to admin_area_volunteers_path, style: "display: block; padding: 15px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 8px; font-weight: 500;" do %>
          <span style="font-size: 20px; margin-right: 10px;">👥</span>Manage Volunteers
        <% end %>

        <%= link_to admin_area_events_path, style: "display: block; padding: 15px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 8px; font-weight: 500;" do %>
          <span style="font-size: 20px; margin-right: 10px;">📅</span>Manage Events
        <% end %>

        <%= link_to admin_area_volunteer_assignments_path, style: "display: block; padding: 15px 20px; background-color: #e7f3ff; color: #004085; text-decoration: none; border-radius: 8px; font-weight: 500; border: 2px solid transparent;" do %>
          <span style="font-size: 20px; margin-right: 10px;">📋</span>Manage Assignments / Approvals
        <% end %>

        <%= link_to admin_area_analytics_path, style: "display: block; padding: 15px 20px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; text-decoration: none; border-radius: 8px; font-weight: 700;" do %>
          <span style="font-size: 20px; margin-right: 10px;">📈</span>Volunteer Analytics
        <% end %>

      </div>
    </div>

    <%# System Overview %>
    <div style="background-color: white; padding: 30px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
      <h2 style="margin: 0 0 25px 0; color: #343a40; font-size: 24px;">System Overview</h2>
      <div style="display: flex; flex-direction: column; gap: 16px;">

        <div style="text-align: center; padding: 20px; background-color: #f8f9fa; border-radius: 8px;">
          <div style="font-size: 14px; color: #6c757d; margin-bottom: 8px; font-weight: bold; text-transform: uppercase;">Volunteer Hours Logged</div>
          <div style="font-size: 32px; font-weight: bold; color: #28a745;"><%= Volunteer.sum(:total_hours) || 0 %></div>
          <div style="font-size: 12px; color: #6c757d;">Total Hours</div>
        </div>

        <div style="text-align: center; padding: 20px; background-color: #f8f9fa; border-radius: 8px;">
          <div style="font-size: 14px; color: #6c757d; margin-bottom: 8px; font-weight: bold; text-transform: uppercase;">Active Events</div>
          <div style="font-size: 32px; font-weight: bold; color: #007bff;"><%= Event.where(status: ['open', 'full']).count %></div>
          <div style="font-size: 12px; color: #6c757d;">Open or Full</div>
        </div>

        <div style="text-align: center; padding: 20px; background-color: #f8f9fa; border-radius: 8px;">
          <div style="font-size: 14px; color: #6c757d; margin-bottom: 8px; font-weight: bold; text-transform: uppercase;">Needs Approval</div>
          <div style="font-size: 32px; font-weight: bold; color: #ffc107;"><%= @pending_assignments %></div>
          <div style="font-size: 12px; color: #6c757d;">
            <%= link_to "Review Now →", admin_area_volunteer_assignments_path(status: 'pending'), style: "color: #007bff; text-decoration: none; font-weight: bold;" %>
          </div>
        </div>

      </div>
    </div>

  </div>

</div>