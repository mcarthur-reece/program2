<h1>Manage Events</h1>

<p>
  <%= link_to "New Event", new_admin_area_event_path %> |
  <%= link_to "Back to Dashboard", admin_path %>
</p>

<table border="1" cellpadding="6">
  <thead>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Date</th>
      <th>Location</th>
      <th>Status</th>
      <th>Approved / Required</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @events.each do |e| %>
      <tr>
        <td><%= e.id %></td>
        <td><%= e.title %></td>
        <td><%= e.event_date %></td>
        <td><%= e.location %></td>
        <td><%= e.status %></td>
        <td><%= e.approved_volunteer_count %> / <%= e.required_number_of_volunteers %></td>
        <td>
          <%= link_to "Show", admin_area_event_path(e) %> |
          <%= link_to "Edit", edit_admin_area_event_path(e) %> |
          <%= button_to "Delete", admin_area_event_path(e),
                method: :delete,
                data: { turbo_confirm: "Delete this event? This will also delete its volunteer assignments." } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
