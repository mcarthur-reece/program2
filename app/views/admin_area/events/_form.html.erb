<div style="max-width: 700px; margin: 50px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; background-color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h1 style="margin-top: 0; margin-bottom: 30px; color: #343a40;"><%= event.persisted? ? 'Edit Event' : 'Create New Event' %></h1>
  
  <%= form_with model: [:admin_area, event], local: true do |f| %>
    <% if event.errors.any? %>
      <div style="color: #721c24; background-color: #f8d7da; margin-bottom: 25px; padding: 15px; border: 1px solid #f5c6cb; border-radius: 4px;">
        <h3 style="margin-top: 0; margin-bottom: 10px; font-size: 18px;">
          <%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:
        </h3>
        <ul style="margin-bottom: 0; padding-left: 20px;">
          <% event.errors.full_messages.each do |msg| %>
            <li style="margin-bottom: 5px;"><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="margin-bottom: 20px;">
      <%= f.label :title, "Event Title:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
      <%= f.text_field :title, 
          placeholder: "e.g., Community Food Drive",
          style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= f.label :description, "Description:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
      <%= f.text_area :description, 
          rows: 4,
          placeholder: "Describe the event, what volunteers will be doing, and any special requirements...",
          style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; resize: vertical; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 20px;">
      <%= f.label :location, "Location:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
      <%= f.text_field :location, 
          placeholder: "e.g., Community Center, 123 Main St",
          style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
      <div>
        <%= f.label :event_date, "Event Date:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.date_field :event_date, 
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>

      <div>
        <%= f.label :required_number_of_volunteers, "Volunteers Needed:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.number_field :required_number_of_volunteers, 
            min: 1, 
            placeholder: "e.g., 10",
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 20px;">
      <div>
        <%= f.label :start_time, "Start Time:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.time_field :start_time, 
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>

      <div>
        <%= f.label :end_time, "End Time:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
        <%= f.time_field :end_time, 
            style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" %>
      </div>
    </div>

    <div style="margin-bottom: 20px;">
      <%= f.label :status, "Event Status:", style: "display: block; margin-bottom: 5px; font-weight: bold; color: #495057;" %>
      <%= f.select :status, 
          Event.statuses.keys.map { |s| [s.titleize, s] },
          {},
          { style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px; box-sizing: border-box;" } %>
      <small style="color: #6c757d; font-size: 14px; display: block; margin-top: 5px;">
        <strong>Open:</strong> Accepting volunteers | <strong>Full:</strong> Capacity reached | <strong>Completed:</strong> Event finished
      </small>
    </div>

    <div style="margin-top: 30px; display: flex; gap: 10px;">
      <%= f.submit event.persisted? ? "Update Event" : "Create Event", 
          style: "flex: 1; padding: 12px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold;" %>
      <%= link_to "Cancel", admin_area_events_path, 
          style: "flex: 1; padding: 12px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-size: 16px; font-weight: bold; display: block; box-sizing: border-box;" %>
    </div>
  <% end %>
</div>