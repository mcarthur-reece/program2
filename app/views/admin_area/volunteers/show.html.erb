<div style="max-width: 900px; margin: 50px auto; padding: 30px; background-color: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  
  <!-- Header Section -->
  <div style="border-bottom: 2px solid #dee2e6; padding-bottom: 20px; margin-bottom: 30px;">
    <div style="display: flex; justify-content: space-between; align-items: start;">
      <div style="flex: 1;">
        <h1 style="margin: 0 0 10px 0; color: #343a40; font-size: 32px;"><%= @volunteer.full_name %></h1>
        <div style="color: #6c757d; font-size: 14px;">
          Volunteer #<%= @volunteer.id %> • 
          <span style="font-family: monospace; background-color: #e9ecef; padding: 2px 6px; border-radius: 3px;">
            @<%= @volunteer.username %>
          </span>
        </div>
      </div>
      
      <div style="text-align: right;">
        <div style="font-size: 36px; font-weight: bold; color: #28a745;">
          <%= @volunteer.total_hours || 0 %>
        </div>
        <div style="color: #6c757d; font-size: 14px; font-weight: bold;">
          TOTAL HOURS
        </div>
      </div>
    </div>
  </div>

  <!-- Contact Information Card -->
  <div style="background-color: #e7f3ff; padding: 20px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #007bff;">
    <h3 style="margin: 0 0 15px 0; color: #004085; font-size: 18px; font-weight: bold;">📧 Contact Information</h3>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
      <div>
        <p style="margin: 0 0 5px 0; color: #6c757d; font-size: 14px; font-weight: bold;">Email</p>
        <p style="margin: 0; color: #004085;">
          <a href="mailto:<%= @volunteer.email %>" style="color: #007bff; text-decoration: none;">
            <%= @volunteer.email %>
          </a>
        </p>
      </div>
      
      <div>
        <p style="margin: 0 0 5px 0; color: #6c757d; font-size: 14px; font-weight: bold;">Phone Number</p>
        <p style="margin: 0; color: #004085;">
          <% if @volunteer.phone_number.present? %>
            <a href="tel:<%= @volunteer.phone_number %>" style="color: #007bff; text-decoration: none;">
              <%= @volunteer.phone_number %>
            </a>
          <% else %>
            <span style="color: #6c757d; font-style: italic;">Not provided</span>
          <% end %>
        </p>
      </div>
    </div>
  </div>

  <!-- Address Card -->
  <div style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #28a745;">
    <h3 style="margin: 0 0 15px 0; color: #495057; font-size: 18px; font-weight: bold;">📍 Address</h3>
    <p style="margin: 0; color: #495057; line-height: 1.6;">
      <%= @volunteer.address.present? ? @volunteer.address : '<span style="color: #6c757d; font-style: italic;">No address provided</span>'.html_safe %>
    </p>
  </div>

  <!-- Skills & Interests Card -->
  <div style="background-color: #fff3cd; padding: 20px; border-radius: 8px; margin-bottom: 20px; border-left: 4px solid #ffc107;">
    <h3 style="margin: 0 0 15px 0; color: #856404; font-size: 18px; font-weight: bold;">⭐ Skills & Interests</h3>
    <p style="margin: 0; color: #856404; line-height: 1.6;">
      <%= @volunteer.skills_interests.present? ? @volunteer.skills_interests : '<span style="color: #6c757d; font-style: italic;">No skills or interests listed</span>'.html_safe %>
    </p>
  </div>

  <!-- Volunteer Activity Card -->
  <div style="background-color: #d4edda; padding: 20px; border-radius: 8px; margin-bottom: 30px; border-left: 4px solid #28a745;">
    <h3 style="margin: 0 0 15px 0; color: #155724; font-size: 18px; font-weight: bold;">📊 Volunteer Activity</h3>
    
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; text-align: center;">
      <div>
        <div style="font-size: 28px; font-weight: bold; color: #155724;">
          <%= @volunteer.volunteer_assignments.count %>
        </div>
        <div style="color: #155724; font-size: 12px; text-transform: uppercase; font-weight: bold;">
          Total Assignments
        </div>
      </div>
      
      <div>
        <div style="font-size: 28px; font-weight: bold; color: #155724;">
          <%= @volunteer.volunteer_assignments.where(status: 'completed').count %>
        </div>
        <div style="color: #155724; font-size: 12px; text-transform: uppercase; font-weight: bold;">
          Completed Events
        </div>
      </div>
      
      <div>
        <div style="font-size: 28px; font-weight: bold; color: #155724;">
          <%= @volunteer.volunteer_assignments.where(status: 'pending').count %>
        </div>
        <div style="color: #155724; font-size: 12px; text-transform: uppercase; font-weight: bold;">
          Pending Approvals
        </div>
      </div>
    </div>
  </div>

  <!-- Action Buttons -->
  <div style="display: flex; gap: 10px; padding-top: 20px; border-top: 1px solid #dee2e6;">
    <%= link_to "✏️ Edit Volunteer", edit_admin_area_volunteer_path(@volunteer), 
        style: "flex: 1; padding: 12px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-weight: bold; font-size: 16px;" %>
    
    <%= link_to "📋 View Assignments", admin_area_volunteer_assignments_path(volunteer_id: @volunteer.id), 
        style: "flex: 1; padding: 12px 20px; background-color: #17a2b8; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-weight: bold; font-size: 16px;" %>
    
    <%= button_to "🗑️ Delete Volunteer", admin_area_volunteer_path(@volunteer),
        method: :delete,
        data: { turbo_confirm: "Are you sure? This will delete all assignments for this volunteer." },
        style: "flex: 1; padding: 12px 20px; background-color: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; font-size: 16px;" %>
  </div>

  <div style="margin-top: 20px; text-align: center;">
    <%= link_to "← Back to All Volunteers", admin_area_volunteers_path, 
        style: "padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px; display: inline-block;" %>
  </div>

</div>