<h1>Manage Volunteers</h1>

<p>
  <%= link_to "New Volunteer", new_admin_area_volunteer_path %> |
  <%= link_to "Back to Dashboard", admin_path %>
</p>

<table border="1" cellpadding="6">
  <thead>
    <tr>
      <th>ID</th>
      <th>Username</th>
      <th>Full Name</th>
      <th>Email</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @volunteers.each do |v| %>
      <tr>
        <td><%= v.id %></td>
        <td><%= v.username %></td>
        <td><%= v.full_name %></td>
        <td><%= v.email %></td>
        <td>
          <%= link_to "Show", admin_area_volunteer_path(v) %> |
          <%= link_to "Edit", edit_admin_area_volunteer_path(v) %> |
          <%= button_to "Delete", admin_area_volunteer_path(v), method: :delete,
                data: { turbo_confirm: "Delete this volunteer?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
