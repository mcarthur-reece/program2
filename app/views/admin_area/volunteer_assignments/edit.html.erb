<div style="max-width: 600px; margin: 50px auto; padding: 30px; border: 1px solid #ddd; border-radius: 8px; background-color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
  <h1>Edit Assignment</h1>
  
  <%= form_with(model: [:admin_area, @assignment], local: true) do |f| %>
    <% if @assignment.errors.any? %>
      <div style="color: #721c24; background-color: #f8d7da; margin-bottom: 20px; padding: 15px; border: 1px solid #f5c6cb; border-radius: 4px;">
        <h3 style="margin-top: 0;"><%= pluralize(@assignment.errors.count, "error") %> prohibited this assignment:</h3>
        <ul style="margin-bottom: 0;">
          <% @assignment.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    
    <div style="margin-bottom: 20px;">
      <%= f.label :volunteer_id, "Volunteer:", style: "display: block; margin-bottom: 5px; font-weight: bold;" %>
      <%= f.select :volunteer_id, 
          options_from_collection_for_select(@volunteers, :id, :full_name, @assignment.volunteer_id), 
          {},
          { required: true, style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px;" } %>
    </div>
    
    <div style="margin-bottom: 20px;">
      <%= f.label :event_id, "Event:", style: "display: block; margin-bottom: 5px; font-weight: bold;" %>
      <%= f.select :event_id, 
          options_from_collection_for_select(@events, :id, :title, @assignment.event_id), 
          {},
          { required: true, style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px;" } %>
    </div>
    
    <div style="margin-bottom: 20px;">
      <%= f.label :status, "Status:", style: "display: block; margin-bottom: 5px; font-weight: bold;" %>
      <%= f.select :status, 
          [['Pending', 'pending'], ['Approved', 'approved'], ['Completed', 'completed'], ['Cancelled', 'cancelled']], 
          { selected: @assignment.status },
          { required: true, style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px;" } %>
    </div>
    
    <hr style="margin: 30px 0; border: none; border-top: 1px solid #dee2e6;">
    
    <h3 style="margin-bottom: 15px;">Volunteer Hours (Optional)</h3>
    <p style="color: #6c757d; font-size: 14px; margin-bottom: 15px;">Only log hours after the event is completed</p>
    
    <div style="margin-bottom: 20px;">
      <%= f.label :hours_worked, "Hours Worked:", style: "display: block; margin-bottom: 5px; font-weight: bold;" %>
      <%= f.number_field :hours_worked, step: 0.5, min: 0, placeholder: "0.0", style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px;" %>
    </div>
    
    <div style="margin-bottom: 20px;">
      <%= f.label :date_logged, "Date Logged:", style: "display: block; margin-bottom: 5px; font-weight: bold;" %>
      <%= f.date_field :date_logged, style: "width: 100%; padding: 10px; border: 1px solid #ced4da; border-radius: 4px; font-size: 16px;" %>
    </div>
    
    <div style="margin-top: 30px; display: flex; gap: 10px;">
      <%= f.submit "Update Assignment", style: "flex: 1; padding: 12px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 16px; font-weight: bold;" %>
      <%= link_to "Cancel", admin_area_volunteer_assignments_path, style: "flex: 1; padding: 12px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px; text-align: center; font-size: 16px; font-weight: bold; display: block;" %>
    </div>
  <% end %>
</div>