<%= form_with model: event do |f| %>
  <% if event.errors.any? %>
    <div>
      <h2><%= pluralize(event.errors.count, "error") %> prevented saving:</h2>
      <ul>
        <% event.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :location %><br>
    <%= f.text_field :location %>
  </div>

  <div>
    <%= f.label :event_date %><br>
    <%= f.date_field :event_date %>
  </div>

  <div>
    <%= f.label :start_time %><br>
    <%= f.time_field :start_time %>
  </div>

  <div>
    <%= f.label :end_time %><br>
    <%= f.time_field :end_time %>
  </div>

  <div>
    <%= f.label :required_number_of_volunteers %><br>
    <%= f.number_field :required_number_of_volunteers, min: 1 %>
  </div>

  <div>
    <%= f.label :status %><br>
    <%= f.select :status, Event.statuses.keys %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
