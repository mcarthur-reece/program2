<h1><%= @event.title %></h1>

<p><strong>Description:</strong> <%= @event.description %></p>
<p><strong>Location:</strong> <%= @event.location %></p>
<p><strong>Date:</strong> <%= @event.event_date %></p>
<p><strong>Time:</strong> <%= @event.start_time.strftime("%H:%M") %> - <%= @event.end_time.strftime("%H:%M") %></p>

<p><strong>Required Volunteers:</strong> <%= @event.required_number_of_volunteers %></p>
<p><strong>Approved Volunteers:</strong> <%= @event.volunteer_assignments.approved.count %></p>
<p><strong>Status:</strong> <%= @event.status %></p>

<% if current_user %>
  <% existing = @event.volunteer_assignments.find_by(volunteer_id: current_user.id) %>

  <% if existing.present? %>
    <p><strong>Your signup status:</strong> <%= existing.status %></p>

    <% if existing.pending? || existing.approved? %>
      <%= button_to "Withdraw from this event",
                    volunteer_assignment_path(existing),
                    method: :delete,
                    data: { turbo_confirm: "Withdraw from this event?" } %>
    <% end %>
  <% elsif @event.open? %>
    <%= button_to "Sign up for this event", signup_event_path(@event), method: :post %>
  <% else %>
    <p>This event is not available for sign-ups.</p>
  <% end %>
<% end %>

<p>
  <%= link_to "Back to Events", events_path %>
  <% if admin_logged_in? %>
    | <%= link_to "Edit", edit_event_path(@event) %>
  <% end %>
</p>
